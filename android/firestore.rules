rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /farmer_profiles/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /fcm_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /crop_recommendations/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /weather_advisories/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /crop_disease_scans/{userId}/scans/{scanId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /voice_conversations/{userId}/messages/{messageId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
